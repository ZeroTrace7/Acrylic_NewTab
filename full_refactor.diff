diff --git a/css/animations.css b/css/animations.css
new file mode 100644
index 0000000..a504537
--- /dev/null
+++ b/css/animations.css
@@ -0,0 +1,174 @@
+/* Animations layer: keyframes and animation utility classes */
+@keyframes toast-in {
+  from {
+    opacity: 0;
+    transform: translateX(24px) scale(0.95);
+  }
+  to {
+    opacity: 1;
+    transform: translateX(0) scale(1);
+  }
+}
+
+@keyframes toast-out {
+  from {
+    opacity: 1;
+    transform: translateX(0) scale(1);
+  }
+  to {
+    opacity: 0;
+    transform: translateX(24px) scale(0.95);
+  }
+}
+
+@keyframes modal-fade-in {
+  from { opacity: 0; }
+  to   { opacity: 1; }
+}
+
+@keyframes modal-slide-in {
+  from {
+    opacity: 0;
+    transform: translateY(16px) scale(0.97);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+  }
+}
+
+@keyframes fade-in-up {
+  from {
+    opacity: 0;
+    transform: translateY(24px) scale(0.98);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+  }
+}
+
+@keyframes fade-in-scale {
+  from {
+    opacity: 0;
+    transform: scale(0.95);
+  }
+  to {
+    opacity: 1;
+    transform: scale(1);
+  }
+}
+
+@keyframes slide-in-up {
+  from {
+    opacity: 0;
+    transform: translateY(20px) scale(0.95);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+  }
+}
+
+@keyframes slide-in-right {
+  from {
+    opacity: 0;
+    transform: translateX(20px) scale(0.95);
+  }
+  to {
+    opacity: 1;
+    transform: translateX(0) scale(1);
+  }
+}
+
+@keyframes pop-in {
+  from {
+    opacity: 0;
+    transform: scale(0.8);
+  }
+  to {
+    opacity: 1;
+    transform: scale(1);
+  }
+}
+
+@keyframes pulse-glow {
+  0%   { opacity: 0.4; }
+  50%  { opacity: 0.8; }
+  100% { opacity: 0.4; }
+}
+
+.animate-fade-in-up {
+  animation: fade-in-up var(--dur-slow) var(--ease-glass) both;
+}
+
+.animate-fade-in-scale {
+  animation: fade-in-scale var(--dur-slow) var(--ease-glass) both;
+}
+
+.animate-slide-in-up {
+  animation: slide-in-up var(--dur-slow) var(--ease-glass) both;
+}
+
+.animate-slide-in-right {
+  animation: slide-in-right var(--dur-slow) var(--ease-glass) both;
+}
+
+.animate-pop-in {
+  animation: pop-in var(--dur-mid) var(--ease-spring) both;
+}
+
+.animate-pulse-glow {
+  animation: pulse-glow 2s ease-in-out infinite;
+}
+
+@keyframes fade-out {
+  from { opacity: 1; transform: translateY(0) scale(1); }
+  to   { opacity: 0; transform: translateY(10px) scale(0.97); }
+}
+
+.animate-fade-out {
+  animation: fade-out var(--dur-mid) var(--ease-glass) both;
+}
+
+.animate-stagger > * {
+  opacity: 0;
+  animation: fade-in-up var(--dur-slow) var(--ease-glass) both;
+}
+
+.animate-stagger > *:nth-child(1) { animation-delay: 0.05s; }
+.animate-stagger > *:nth-child(2) { animation-delay: 0.12s; }
+.animate-stagger > *:nth-child(3) { animation-delay: 0.20s; }
+.animate-stagger > *:nth-child(4) { animation-delay: 0.28s; }
+.animate-stagger > *:nth-child(5) { animation-delay: 0.36s; }
+
+@keyframes acrylic-enter {
+  from {
+    opacity: 0;
+  }
+  to {
+    opacity: 1;
+  }
+}
+
+#top-bar {
+  animation: acrylic-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
+  animation-delay: 0s;
+}
+
+#left-dock {
+  animation: acrylic-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both;
+}
+
+#clock-zone {
+  animation: acrylic-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
+}
+
+#middle-zone {
+  animation: acrylic-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
+}
+
+#quicklinks-zone {
+  animation: acrylic-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
+}
+
diff --git a/css/components.css b/css/components.css
new file mode 100644
index 0000000..1fee787
--- /dev/null
+++ b/css/components.css
@@ -0,0 +1,386 @@
+/* Components layer: reusable UI blocks without page-zone positioning */
+.glass {
+  background: rgba(255, 255, 255, 0.08);
+  backdrop-filter: blur(var(--glass-blur));
+  -webkit-backdrop-filter: blur(var(--glass-blur));
+  border: 1px solid rgba(255, 255, 255, 0.20);
+  border-radius: var(--glass-radius);
+  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.15);
+}
+
+.glass-subtle {
+  background: var(--glass-subtle);
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+  border: 1px solid var(--glass-border-soft);
+  border-radius: var(--glass-radius-sm);
+  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.10);
+}
+
+.glass:hover {
+  background: var(--glass-bg-hover);
+  border-color: rgba(255, 255, 255, 0.24);
+  box-shadow: var(--glass-shadow-lg), var(--glass-inset);
+}
+
+.icon-btn {
+  width: 38px;
+  height: 38px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 12px;
+  background: rgba(255, 255, 255, 0.06);
+  backdrop-filter: blur(10px);
+  -webkit-backdrop-filter: blur(10px);
+  border: 1px solid rgba(255, 255, 255, 0.15);
+  color: var(--text-secondary);
+  transition:
+    transform var(--dur-fast) var(--ease-spring),
+    background var(--dur-mid) var(--ease-glass),
+    border-color var(--dur-mid) var(--ease-glass),
+    box-shadow var(--dur-mid) var(--ease-glass);
+}
+
+.icon-btn:hover {
+  background: rgba(255, 255, 255, 0.12);
+  border-color: rgba(255, 255, 255, 0.25);
+  color: var(--text-primary);
+  transform: translateY(-2px) scale(1.05);
+  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
+}
+
+.icon-btn:active {
+  transform: scale(0.92);
+}
+
+#search-section,
+.search-section {
+  width: 100%;
+  max-width: min(640px, 90vw);
+  position: relative;
+  margin-top: 0;
+}
+
+#search-wrapper {
+  width: min(620px, 85vw);
+  margin: 0 auto;
+}
+
+.search-wrapper {
+  display: flex;
+  align-items: center;
+  gap: var(--space-sm);
+  padding: 6px 8px 6px 6px;
+  transition: all var(--dur-mid) var(--ease-glass);
+}
+
+.search-wrapper:focus-within {
+  background: var(--glass-bg-hover);
+  border-color: rgba(255, 255, 255, 0.30);
+  box-shadow:
+    var(--glass-shadow-lg),
+    var(--glass-inset),
+    0 0 0 3px rgba(255, 255, 255, 0.06);
+}
+
+.search-engine-btn {
+  width: 34px;
+  height: 34px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: var(--glass-radius-sm);
+  cursor: pointer;
+  transition: all var(--dur-mid) var(--ease-glass);
+}
+
+.search-engine-btn:hover {
+  background: var(--glass-bg);
+  transform: scale(1.05);
+}
+
+.search-engine-btn img {
+  width: 20px;
+  height: 20px;
+  object-fit: contain;
+}
+
+.search-input {
+  flex: 1;
+  background: transparent;
+  border: none;
+  outline: none;
+  font-size: clamp(0.875rem, 1.3vw, 1.05rem);
+  color: var(--text-primary);
+  caret-color: rgba(255, 255, 255, 0.8);
+}
+
+.search-input::placeholder {
+  color: var(--text-muted);
+}
+
+.search-submit {
+  width: 34px;
+  height: 34px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: var(--text-secondary);
+  transition: all var(--dur-mid) var(--ease-glass);
+}
+
+.search-submit:hover {
+  color: var(--text-primary);
+  background: var(--glass-bg);
+  transform: scale(1.05);
+}
+
+.search-submit:active {
+  transform: scale(0.95);
+}
+
+.engine-picker {
+  position: absolute;
+  top: calc(100% + 8px);
+  left: 0;
+  min-width: 220px;
+  padding: var(--space-sm);
+  z-index: 100;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+
+.engine-option {
+  display: flex;
+  align-items: center;
+  gap: var(--space-sm);
+  padding: 8px 12px;
+  border-radius: var(--glass-radius-sm);
+  font-size: 0.875rem;
+  color: var(--text-secondary);
+  cursor: pointer;
+  transition: all var(--dur-fast) var(--ease-glass);
+}
+
+.engine-option:hover,
+.engine-option.active {
+  background: var(--glass-subtle);
+  color: var(--text-primary);
+}
+
+#quicklinks-section,
+.quicklinks-section {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 6px;
+}
+
+.quicklinks-grid {
+  display: flex;
+  flex-wrap: wrap;
+  justify-content: center;
+  gap: 12px;
+}
+
+.quicklink-tile {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  width: 48px;
+  height: 48px;
+  border-radius: 16px;
+  background: rgba(150, 150, 150, 0.15);
+  backdrop-filter: blur(12px);
+  -webkit-backdrop-filter: blur(12px);
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  box-shadow: none;
+  cursor: pointer;
+  text-decoration: none;
+  color: rgba(255, 255, 255, 0.8);
+  transition: all 0.15s cubic-bezier(.4, 0, .2, 1);
+}
+
+.quicklink-tile:hover {
+  transform: scale(1.05);
+}
+
+.quicklink-tile:active {
+  transform: scale(0.96);
+}
+
+.quicklink-favicon {
+  width: 20px;
+  height: 20px;
+  object-fit: contain;
+  border-radius: 4px;
+}
+
+.quicklink-favicon-placeholder {
+  width: 20px;
+  height: 20px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 4px;
+  background: transparent;
+  color: rgba(255, 255, 255, 0.8);
+  font-size: 11px;
+  font-weight: 600;
+  text-transform: uppercase;
+}
+
+.quicklink-item {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 6px;
+}
+
+.quicklink-label {
+  font-size: 0.65rem;
+  font-weight: 400;
+  text-align: center;
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  max-width: 48px;
+  color: rgba(255, 255, 255, 0.8);
+}
+
+.add-link-btn {
+  width: clamp(68px, 7vw, 88px);
+  height: clamp(34px, 3.5vw, 42px);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: var(--text-muted);
+  transition: all var(--dur-mid) var(--ease-glass);
+}
+
+.add-link-btn:hover {
+  background: var(--glass-subtle);
+  color: var(--text-primary);
+  transform: scale(1.05);
+}
+
+.add-link-btn:active {
+  transform: scale(0.95);
+}
+
+.fab {
+  width: 52px;
+  height: 52px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: var(--text-secondary);
+  border-radius: 50%;
+  cursor: pointer;
+  flex-shrink: 0;
+  transition:
+    transform var(--dur-mid) var(--ease-spring),
+    background var(--dur-mid) var(--ease-glass),
+    color var(--dur-mid) var(--ease-glass),
+    box-shadow var(--dur-mid) var(--ease-glass);
+}
+
+.fab:hover {
+  color: var(--text-primary);
+  background: rgba(255, 255, 255, 0.12);
+  transform: scale(1.12);
+  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
+}
+
+.fab:active {
+  transform: scale(0.92);
+}
+
+.fab.active {
+  background: rgba(255, 255, 255, 0.18);
+  color: var(--text-primary);
+  transform: rotate(45deg) scale(1.05);
+}
+
+#toast-container {
+  position: fixed;
+  top: 20px;
+  right: 20px;
+  z-index: 9999;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  pointer-events: none;
+}
+
+.toast {
+  padding: 10px 16px;
+  border-radius: var(--glass-radius-sm);
+  font-size: 0.8125rem;
+  font-weight: 500;
+  color: var(--text-primary);
+  background: rgba(255, 255, 255, 0.15);
+  backdrop-filter: blur(16px);
+  -webkit-backdrop-filter: blur(16px);
+  border: 1px solid rgba(255, 255, 255, 0.20);
+  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.20);
+  pointer-events: auto;
+  animation: toast-in var(--dur-mid) var(--ease-spring) both;
+}
+
+.toast.success {
+  border-color: rgba(52, 211, 153, 0.4);
+}
+
+.toast.error {
+  border-color: rgba(248, 113, 113, 0.4);
+}
+
+.toast.dismissing {
+  animation: toast-out var(--dur-mid) var(--ease-glass) both;
+}
+
+.modal-overlay {
+  position: fixed;
+  inset: 0;
+  z-index: 200;
+  background: rgba(0, 0, 0, 0.55);
+  backdrop-filter: blur(6px);
+  -webkit-backdrop-filter: blur(6px);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: var(--space-md);
+  animation: modal-fade-in var(--dur-mid) var(--ease-glass) both;
+}
+
+.modal-box {
+  width: min(480px, 94vw);
+  max-height: 90vh;
+  overflow-y: auto;
+  border-radius: var(--glass-radius-lg);
+  background: rgba(255, 255, 255, 0.12);
+  backdrop-filter: blur(24px);
+  -webkit-backdrop-filter: blur(24px);
+  border: 1px solid rgba(255, 255, 255, 0.20);
+  box-shadow:
+    0 32px 80px rgba(0, 0, 0, 0.4),
+    inset 0 1px 0 rgba(255, 255, 255, 0.15);
+  padding: var(--space-xl);
+  animation: modal-slide-in var(--dur-mid) var(--ease-spring) both;
+}
+
+@media (max-width: 768px) {
+  .quicklinks-grid {
+    gap: 8px;
+  }
+
+  .fab {
+    width: 46px;
+    height: 46px;
+  }
+}
+
diff --git a/css/layout.css b/css/layout.css
new file mode 100644
index 0000000..0c0f7fc
--- /dev/null
+++ b/css/layout.css
@@ -0,0 +1,111 @@
+/* Layout layer: page zones and positioning constants */
+:root {
+  --clock-top: 6vh;
+  --center-top: 53%;
+  --quicklinks-bottom: 5vh;
+  --sidebar-left: 20px;
+}
+
+.layout-root {
+  position: relative;
+  width: 100vw;
+  height: 100vh;
+  overflow: hidden;
+  z-index: 1;
+}
+
+.left-dock,
+#left-dock {
+  position: absolute;
+  left: var(--sidebar-left);
+  top: 50%;
+  transform: translateY(-50%);
+  width: 66px;
+  height: auto;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 12px;
+  z-index: 30;
+}
+
+#clock-zone {
+  position: absolute;
+  top: var(--clock-top);
+  left: 50%;
+  transform: translateX(-50%);
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+}
+
+#middle-zone {
+  position: absolute;
+  top: var(--center-top);
+  left: 50%;
+  transform: translate(-50%, -50%);
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  gap: 18px;
+  width: 100%;
+  max-width: 720px;
+  pointer-events: auto;
+}
+
+#quicklinks-zone {
+  position: absolute;
+  bottom: var(--quicklinks-bottom);
+  left: 50%;
+  transform: translateX(-50%);
+}
+
+.right-panel,
+#right-panel {
+  position: fixed;
+  right: 0;
+  top: 0;
+  height: 100%;
+  width: 320px;
+  transform: translateX(100%);
+  transition: transform 300ms cubic-bezier(.4, 0, .2, 1);
+  z-index: 40;
+  pointer-events: none;
+}
+
+.right-panel.open,
+#right-panel.open {
+  transform: translateX(0);
+  pointer-events: auto;
+}
+
+.top-bar,
+#top-bar {
+  position: absolute;
+  top: 24px;
+  right: 24px;
+  left: auto;
+  width: auto;
+  display: flex;
+  align-items: center;
+  z-index: 20;
+}
+
+#tools-fab,
+.dock-grid-btn {
+  position: fixed;
+  left: 24px;
+  bottom: 24px;
+  top: auto;
+  transform: none;
+  z-index: 40;
+}
+
+@media (max-width: 768px) {
+  .left-dock,
+  #left-dock {
+    left: 16px;
+  }
+}
+
diff --git a/css/panels.css b/css/panels.css
new file mode 100644
index 0000000..56a2f4e
--- /dev/null
+++ b/css/panels.css
@@ -0,0 +1,47 @@
+/* Panels layer: tools panel specific UI styles */
+#tools-panel {
+  width: 100%;
+  height: 100%;
+  display: flex;
+  flex-direction: column;
+  overflow: hidden;
+}
+
+.panel-header {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  padding: 16px 16px 0 16px;
+  flex-shrink: 0;
+}
+
+.panel-tabs {
+  display: flex;
+  gap: 4px;
+  padding: 12px 16px 0 16px;
+  flex-shrink: 0;
+}
+
+.panel-tab-btn {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 4px;
+  padding: 8px 4px;
+  border-radius: 12px;
+  font-size: 0.7rem;
+  font-weight: 500;
+  color: var(--text-secondary);
+  cursor: pointer;
+  transition: all 150ms ease;
+  border: 1px solid transparent;
+}
+
+#panel-content {
+  flex: 1;
+  overflow-y: auto;
+  padding: 16px;
+  min-height: 0;
+}
+
